# Docker Compose 部署环境变量示例
# 使用方式：
# cp docker/.env.example docker/.env
# docker compose --env-file docker/.env -f docker/docker-compose.yml up -d

# PostgreSQL 超级用户名。
# Bitnami PostgreSQL 镜像会用它初始化默认库 postgres。
STATION_DB_USERNAME=postgres

# PostgreSQL 超级用户密码。
# 同时用于：
# 1. PostgreSQL 容器启动
# 2. postgres-init 创建业务数据库
# 3. Gitea 连接 PostgreSQL
# 4. wp-station 连接 PostgreSQL（通过 WP_STATION__DATABASE__PASSWORD 覆盖 config.toml）
STATION_DB_PASSWORD=A7GaKXT3JEY3_Qrh

# Gitea 管理员账号 gitea 的密码。
# 同时用于：
# 1. gitea-init 初始化管理员账号
# 2. wp-station 访问 Gitea API 与 Git 同步（通过 WP_STATION__GITEA__PASSWORD 覆盖 config.toml）
STATION_GITEA_ADMIN_PASSWORD=123456

# wp-station 从容器网络访问 Gitea 的地址。
# 覆盖 config.toml 中的 [gitea].base_url，默认使用 Docker Compose 服务名 gitea。
STATION_GITEA_BASE_URL=http://gitea:3000

# AI Assist 服务地址。
# 覆盖 config.toml 中的 [assist].base_url
STATION_ASSIST_BASE_URL=http://assist:8888

# 数据采集服务地址。
# 覆盖 config.toml 中的 [features].data_collect_url
STATION_DATA_COLLECT_URL=http://159.75.67.240:18080/
